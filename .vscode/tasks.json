{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ROS2 Workspace",
            "type": "shell",
            "command": "cd DOOM && colcon build",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Source ROS2 Workspace",
            "type": "shell",
            "command": "source install/setup.bash",
            "problemMatcher": []
        },
        {
            "label": "Format & Lint",
            "type": "shell",
            "command": "isort . && black . --line-length 120 --exclude 'build|install|share' && python3 -m flake8 --exclude build,install,share --max-line-length=120",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build and Format",
            "dependsOn": [
                "Build ROS2 Workspace",
                "Source ROS2 Workspace",
                "Format & Lint"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}