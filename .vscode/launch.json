{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Contact Sim Go2 debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/master_manager/master_manager/master_node.py",
            "args": [
                "--task",
                "rl-contact-sim-go2",
                "--log",
                "test"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build_ros2_workspace",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/install/lib/python3.10/site-packages:${env:PYTHONPATH}",
                "LD_LIBRARY_PATH": "${workspaceFolder}/install/lib:${env:LD_LIBRARY_PATH}",
                "ROS_DISTRO": "humble",
                "ROS_VERSION": "2"
            },
            "justMyCode": false
        },
